---
import Results from "@/layouts/Results.astro";
const { query } = Astro.params
import SearchBox from "@/components/SearchBox.astro";
import { Card, CardDescription, CardHeader, CardTitle, CardFooter } from "@/components/ui/card";
import { OramaClient } from "@oramacloud/client";
import { Button } from "@/components/ui/button.tsx";
const client = new OramaClient({
    endpoint: import.meta.env.ORAMA_ENDPOINT,
    api_key: import.meta.env.ORAMA_API_KEY
});

const result = await client.search({
    term: query,
    mode: "fulltext",
})

---

<Results title={"Searched for \'" + query + "\'"}>
    <div class="col-span-2 sticky top-0  border-border border-b-2  bg-shadedBg dark:bg-secondaryBlack p-5 flex gap-3 flex-col">
        <h1 class="text-4xl flex dark:text-main font-peta">Search</h1>
        <SearchBox />
    <p>Found {result.hits.length} {result.hits.length === 1 ? "result" : "results"}</p>
    </div>
    <div class="grid grid-cols-2 p-3 gap-3 col-span-4">
        {result.hits.map((hit) => (
            <Card>
                
                <CardHeader className="flex flex-row">
                    <img src={hit.document.img} alt={hit.document.name} class="m-2 rounded-sm border-border border-2 mr-0 max-h-24 " />

                    <div class="p-3 flex flex-col">
                    <CardTitle>{hit.document.name}</CardTitle>
                    <CardDescription>{hit.document.artist}</CardDescription>
                    </div>
                </CardHeader>
                <CardFooter className="flex flex-row items-end">
                    <p class="dark:text-darkText">{hit.document.copyright}</p>
                    <div onclick={"window.location.href = " + "'/song/" + hit.document.uuid + "'"} class="ml-auto">
                    <Button>View</Button>
                    </div>
                </CardFooter>
            </Card>
        ))}
        </div>
    </Results>
