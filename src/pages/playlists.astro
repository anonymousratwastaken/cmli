---
import Page from "@/layouts/Page.astro";
import { Button } from "@/components/ui/button";
---

<Page title="Playlists">
    <div class="flex flex-col gap-5 min-h-full items-center text-center p-3 content-center justify-center">
        <h1 class="text-4xl font-bold dark:text-main">Playlists</h1>
        <p class="max-w-4xl">Create and manage your playlists here.</p>
        <Button onclick="window.location.href='/playlists/new'">Create New Playlist</Button>
    </div>
</Page>